# ──────────────────────────────────────────────────────────────────────────────
# secrets.yaml  (EXAMPLE)
#
# 1. Copy this file to "secrets.yaml" in the same folder:
#        cp secrets.yaml.example secrets.yaml
# 2. Fill in your real values below.
# 3. NEVER commit secrets.yaml — it is already listed in .gitignore.
#
# ESPHome automatically reads secrets.yaml that sits next to the dashboard YAML
# and substitutes every `!secret <name>` reference with the value here.
# ──────────────────────────────────────────────────────────────────────────────

# Your 2.4 GHz Wi-Fi network (the ESP32-S3 has no 5 GHz radio).
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
